<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Scholara — Research Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c0f;
    --surface: #111318;
    --surface2: #181c24;
    --border: rgba(255,255,255,0.07);
    --accent: #c8f04a;
    --accent2: #4af0c8;
    --text: #e8eaf0;
    --muted: #6b7280;
    --paper-bg: #13161e;
    --danger: #f04a4a;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,240,74,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,240,74,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  .shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 210px 255px 1fr;
    grid-template-rows: 54px 1fr;
    height: 100vh;
  }

  /* NAV */
  nav {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    padding: 0 20px;
    border-bottom: 1px solid var(--border);
    background: rgba(10,12,15,0.95);
    backdrop-filter: blur(12px);
    gap: 12px;
    z-index: 100;
  }
  .logo { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; color: var(--accent); }
  .logo span { color: var(--text); }
  .nav-sep { width: 1px; height: 18px; background: var(--border); }
  .nav-badge { font-family: 'DM Mono', monospace; font-size: 10px; padding: 3px 10px; border-radius: 20px; border: 1px solid rgba(74,240,200,0.3); color: var(--accent2); background: rgba(74,240,200,0.05); }
  .nav-spacer { flex: 1; }
  .nav-hint { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); }

  /* PANEL SHARED */
  .panel { border-right: 1px solid var(--border); background: var(--surface); display: flex; flex-direction: column; overflow: hidden; }
  .panel-head { padding: 12px 12px 10px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 8px; }
  .panel-title { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; color: var(--muted); text-transform: uppercase; flex: 1; }

  /* NEW CHAT BUTTON */
  .new-chat-btn {
    background: var(--accent);
    border: none;
    border-radius: 7px;
    width: 26px; height: 26px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 18px; font-weight: 700;
    color: #0a0c0f;
    transition: all 0.2s;
    line-height: 1;
  }
  .new-chat-btn:hover { opacity: 0.85; transform: scale(1.06); }

  /* SESSION LIST */
  .session-list { flex: 1; overflow-y: auto; padding: 6px; display: flex; flex-direction: column; gap: 2px; }

  .session-item {
    border-radius: 8px;
    padding: 8px 9px;
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    gap: 7px;
    border: 1px solid transparent;
  }
  .session-item:hover { background: var(--surface2); }
  .session-item.active { background: rgba(200,240,74,0.07); border-color: rgba(200,240,74,0.2); }
  .session-item.active .s-name { color: var(--accent); }

  .s-icon { font-size: 12px; flex-shrink: 0; }
  .s-info { flex: 1; min-width: 0; }
  .s-name { font-size: 12px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
  .s-meta { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--muted); margin-top: 1px; }

  .s-actions { display: none; gap: 1px; flex-shrink: 0; }
  .session-item:hover .s-actions { display: flex; }

  .s-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 11px; padding: 2px 4px; border-radius: 4px; transition: all 0.15s; }
  .s-btn:hover { background: var(--surface); color: var(--text); }
  .s-btn.del:hover { color: var(--danger); }

  .s-rename-input { font-size: 11px; font-family: 'DM Sans', sans-serif; background: var(--paper-bg); border: 1px solid var(--accent2); border-radius: 4px; color: var(--text); padding: 2px 5px; width: 100%; outline: none; }

  .no-sessions { text-align: center; padding: 24px 10px; color: var(--muted); font-size: 11px; font-family: 'DM Mono', monospace; line-height: 1.8; }

  /* LIBRARY */
  .lib-scroll { flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 14px; }
  .lib-sec-title { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 2px; color: var(--muted); text-transform: uppercase; margin-bottom: 7px; padding-bottom: 5px; border-bottom: 1px solid var(--border); }

  .upload-zone { border: 1.5px dashed var(--border); border-radius: 9px; padding: 14px; text-align: center; cursor: pointer; transition: all 0.3s; background: var(--paper-bg); position: relative; }
  .upload-zone:hover, .upload-zone.drag-over { border-color: var(--accent); background: rgba(200,240,74,0.04); }
  .upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; }
  .upload-zone p { font-size: 11px; color: var(--muted); line-height: 1.5; }
  .upload-zone strong { color: var(--accent); }

  .arxiv-row { display: flex; gap: 5px; }
  .arxiv-input { flex: 1; background: var(--paper-bg); border: 1px solid var(--border); border-radius: 7px; padding: 7px 9px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 11px; outline: none; transition: border-color 0.2s; }
  .arxiv-input:focus { border-color: var(--accent2); }
  .arxiv-input::placeholder { color: var(--muted); }

  .btn-sm { background: var(--accent2); border: none; border-radius: 7px; padding: 7px 11px; color: #0a0c0f; font-weight: 600; font-size: 11px; cursor: pointer; transition: opacity 0.2s; white-space: nowrap; }
  .btn-sm:hover { opacity: 0.85; }
  .btn-sm:disabled { opacity: 0.4; cursor: not-allowed; }

  .paper-list { display: flex; flex-direction: column; gap: 5px; }
  .paper-card { background: var(--paper-bg); border: 1px solid var(--border); border-radius: 8px; padding: 9px; transition: border-color 0.2s; position: relative; }
  .paper-card:hover { border-color: rgba(200,240,74,0.22); }
  .pc-title { font-size: 11px; font-weight: 500; color: var(--text); line-height: 1.4; margin-bottom: 2px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; padding-right: 14px; }
  .pc-meta { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--muted); }
  .pc-tag { display: inline-block; font-family: 'DM Mono', monospace; font-size: 9px; padding: 1px 5px; border-radius: 3px; background: rgba(74,240,200,0.1); color: var(--accent2); margin-top: 3px; }
  .pc-remove { position: absolute; top: 5px; right: 5px; background: none; border: none; color: var(--muted); cursor: pointer; font-size: 12px; opacity: 0; transition: opacity 0.2s; }
  .paper-card:hover .pc-remove { opacity: 1; }
  .p-badge { background: var(--accent); color: #0a0c0f; font-size: 9px; font-weight: 700; padding: 1px 5px; border-radius: 8px; margin-left: 4px; font-family: 'DM Mono', monospace; }
  .empty-state { text-align: center; padding: 10px; color: var(--muted); font-size: 10px; font-family: 'DM Mono', monospace; }

  /* MAIN */
  .main { display: flex; flex-direction: column; overflow: hidden; }

  .mode-tabs { display: flex; gap: 2px; padding: 9px 18px; border-bottom: 1px solid var(--border); background: var(--surface); flex-shrink: 0; }
  .mode-tab { padding: 6px 13px; border-radius: 7px; font-size: 12px; cursor: pointer; color: var(--muted); border: 1px solid transparent; transition: all 0.2s; }
  .mode-tab:hover { color: var(--text); }
  .mode-tab.active { background: var(--paper-bg); border-color: var(--border); color: var(--accent); }

  .stats-bar { display: flex; gap: 16px; padding: 5px 18px; border-bottom: 1px solid var(--border); background: rgba(17,19,24,0.7); flex-shrink: 0; }
  .stat-i { display: flex; align-items: center; gap: 5px; font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); }
  .stat-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent2); }
  .stat-i span { color: var(--accent2); }

  /* CHAT VIEW */
  #view-chat { display: flex; flex-direction: column; flex: 1; overflow: hidden; }

  .chat-area { flex: 1; overflow-y: auto; padding: 18px; display: flex; flex-direction: column; gap: 14px; }

  .welcome { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; text-align: center; gap: 12px; padding: 28px; }
  .welcome-glyph { font-size: 38px; filter: drop-shadow(0 0 14px rgba(200,240,74,0.28)); }
  .welcome h1 { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 600; background: linear-gradient(135deg, var(--text), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .welcome p { color: var(--muted); font-size: 13px; max-width: 400px; line-height: 1.7; }
  .chips { display: flex; flex-wrap: wrap; gap: 7px; justify-content: center; margin-top: 5px; }
  .chip { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 6px 13px; font-size: 12px; color: var(--text); cursor: pointer; transition: all 0.2s; }
  .chip:hover { border-color: var(--accent); color: var(--accent); }

  .message { display: flex; gap: 9px; animation: fs 0.25s ease-out; }
  @keyframes fs { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
  .message.user { flex-direction: row-reverse; }

  .av { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
  .av.ai { background: linear-gradient(135deg,rgba(200,240,74,0.14),rgba(74,240,200,0.14)); border: 1px solid rgba(200,240,74,0.22); }
  .av.usr { background: var(--surface2); border: 1px solid var(--border); }

  .bubble { max-width: 74%; padding: 11px 15px; border-radius: 12px; font-size: 13px; line-height: 1.7; }
  .message.ai .bubble { background: var(--surface2); border: 1px solid var(--border); border-top-left-radius: 3px; }
  .message.user .bubble { background: rgba(200,240,74,0.07); border: 1px solid rgba(200,240,74,0.16); border-top-right-radius: 3px; }
  .bubble h3 { font-family: 'Playfair Display', serif; font-size: 13px; color: var(--accent); margin-bottom: 5px; }
  .bubble ul { padding-left: 15px; margin: 5px 0; }
  .bubble li { margin-bottom: 3px; }
  .bubble strong { color: var(--accent2); }
  .src-chips { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 9px; padding-top: 9px; border-top: 1px solid var(--border); }
  .src-chip { font-family: 'DM Mono', monospace; font-size: 9px; padding: 2px 6px; border-radius: 4px; background: rgba(200,240,74,0.07); color: var(--accent); border: 1px solid rgba(200,240,74,0.16); }

  .typing-ind { display: flex; gap: 4px; align-items: center; padding: 3px 0; }
  .t-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); animation: bo 1.2s infinite; }
  .t-dot:nth-child(2) { animation-delay:.2s; } .t-dot:nth-child(3) { animation-delay:.4s; }
  @keyframes bo { 0%,60%,100%{transform:translateY(0);opacity:.4} 30%{transform:translateY(-5px);opacity:1} }

  .input-bar { padding: 11px 18px; border-top: 1px solid var(--border); background: var(--surface); display: flex; gap: 7px; align-items: flex-end; flex-shrink: 0; }
  .mode-sel { background: var(--paper-bg); border: 1px solid var(--border); border-radius: 7px; padding: 8px 9px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 11px; outline: none; cursor: pointer; flex-shrink: 0; }
  .q-input { flex: 1; background: var(--paper-bg); border: 1px solid var(--border); border-radius: 10px; padding: 9px 13px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 13px; resize: none; outline: none; min-height: 42px; max-height: 120px; line-height: 1.5; transition: border-color 0.2s; }
  .q-input:focus { border-color: var(--accent2); }
  .q-input::placeholder { color: var(--muted); }
  .send-btn { background: var(--accent); border: none; border-radius: 10px; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; flex-shrink: 0; font-size: 16px; color: #0a0c0f; }
  .send-btn:hover { opacity: .85; transform: scale(1.03); }
  .send-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

  /* TOOL VIEWS */
  .tool-view { display: none; flex-direction: column; flex: 1; overflow: hidden; }
  .tool-view.tv-active { display: flex; }
  .tool-bar { padding: 10px 18px; border-bottom: 1px solid var(--border); display: flex; gap: 7px; align-items: center; flex-wrap: wrap; background: var(--surface); flex-shrink: 0; }
  .tool-body { flex: 1; overflow-y: auto; padding: 18px; display: flex; flex-direction: column; gap: 12px; }
  .sum-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(255px,1fr)); gap: 12px; }
  .sum-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 11px; padding: 14px; animation: fs 0.3s ease-out; }
  .sum-card h4 { font-family: 'Playfair Display', serif; font-size: 13px; margin-bottom: 7px; color: var(--text); line-height: 1.4; }
  .sum-card p { font-size: 12px; color: #9ca3af; line-height: 1.6; }
  .sum-card .tags { margin-top: 9px; display: flex; gap: 5px; flex-wrap: wrap; }
  .sum-card .tag { font-family: 'DM Mono', monospace; font-size: 9px; padding: 2px 6px; border-radius: 3px; background: rgba(74,240,200,0.07); color: var(--accent2); border: 1px solid rgba(74,240,200,0.13); }
  .load-card { text-align: center; padding: 26px; color: var(--muted); font-size: 12px; }
  .spin { width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: sp .8s linear infinite; margin: 0 auto 9px; }
  @keyframes sp { to { transform:rotate(360deg); } }

  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .hidden { display: none !important; }

  .toast { position: fixed; bottom: 18px; right: 18px; background: var(--surface2); border: 1px solid var(--accent2); color: var(--accent2); padding: 9px 15px; border-radius: 8px; font-family: 'DM Mono', monospace; font-size: 11px; z-index: 9999; animation: fs .25s ease-out; max-width: 270px; }

  .confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 9998; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .confirm-box { background: var(--surface2); border: 1px solid var(--border); border-radius: 13px; padding: 22px; max-width: 300px; text-align: center; }
  .confirm-box h3 { font-family: 'Playfair Display', serif; font-size: 15px; margin-bottom: 7px; }
  .confirm-box p { color: var(--muted); font-size: 12px; margin-bottom: 16px; }
  .confirm-btns { display: flex; gap: 8px; justify-content: center; }
  .btn-ok { background: var(--danger); color: #fff; border: none; border-radius: 7px; padding: 7px 18px; font-size: 12px; cursor: pointer; }
  .btn-ok:hover { opacity: .85; }
  .btn-no { background: var(--surface); color: var(--text); border: 1px solid var(--border); border-radius: 7px; padding: 7px 18px; font-size: 12px; cursor: pointer; }
</style>
</head>
<body>
<div class="shell">

  <!-- NAV -->
  <nav>
    <div class="logo">Schola<span>ra</span></div>
    <div class="nav-sep"></div>
    <div class="nav-badge">⚡ Claude AI</div>
    <div class="nav-spacer"></div>
    <div class="nav-hint">Research Intelligence v2</div>
  </nav>

  <!-- COL 1: CHAT HISTORY -->
  <div class="panel">
    <div class="panel-head">
      <span class="panel-title">Chats</span>
      <button class="new-chat-btn" onclick="newChat()" title="New Chat">+</button>
    </div>
    <div class="session-list" id="sessionList">
      <div class="no-sessions">No chats yet.<br>Click + to start.</div>
    </div>
  </div>

  <!-- COL 2: LIBRARY -->
  <div class="panel">
    <div class="panel-head">
      <span class="panel-title">Papers <span id="pBadge" class="p-badge hidden">0</span></span>
    </div>
    <div class="lib-scroll">
      <div>
        <div class="lib-sec-title">📄 Upload</div>
        <div class="upload-zone" id="uz">
          <input type="file" accept=".pdf,.txt" multiple id="fi">
          <span style="font-size:18px;display:block;margin-bottom:5px;">⬆</span>
          <p>Drop PDFs / TXT or <strong>click</strong></p>
        </div>
      </div>
      <div>
        <div class="lib-sec-title">🔎 Search arXiv / PubMed</div>
        <div class="arxiv-row">
          <input class="arxiv-input" id="aq" placeholder="e.g. CRISPR gene editing" />
          <button class="btn-sm" id="aBtn" onclick="searchArxiv()">Find</button>
        </div>
      </div>
      <div>
        <div class="lib-sec-title">📚 Library</div>
        <div class="paper-list" id="paperList">
          <div class="empty-state">No papers yet.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- COL 3: MAIN -->
  <main class="main">

    <div class="mode-tabs">
      <div class="mode-tab active" id="tab-chat" onclick="switchView('chat')">💬 Ask / Q&A</div>
      <div class="mode-tab" id="tab-summary" onclick="switchView('summary')">📋 Summarize</div>
      <div class="mode-tab" id="tab-compare" onclick="switchView('compare')">⚖️ Compare</div>
      <div class="mode-tab" id="tab-extract" onclick="switchView('extract')">🔬 Extract</div>
    </div>

    <div class="stats-bar">
      <div class="stat-i"><div class="stat-dot"></div>Papers: <span id="sPapers">0</span></div>
      <div class="stat-i"><div class="stat-dot" style="background:var(--accent)"></div>Chat: <span id="sChatName">—</span></div>
      <div class="stat-i"><div class="stat-dot" style="background:#c84af0"></div>Messages: <span id="sMsgs">0</span></div>
    </div>

    <!-- CHAT VIEW -->
    <div id="view-chat">
      <div class="chat-area" id="chatArea">
        <div class="welcome" id="wlc">
          <div class="welcome-glyph">🧬</div>
          <h1>Research Intelligence</h1>
          <p>Upload papers or search databases. Ask anything — I'll synthesize findings, compare studies, and extract insights.</p>
          <div class="chips">
            <div class="chip" onclick="useChip(this)">What are the key findings?</div>
            <div class="chip" onclick="useChip(this)">Compare methodologies</div>
            <div class="chip" onclick="useChip(this)">Extract stats & sample sizes</div>
            <div class="chip" onclick="useChip(this)">Summarize conclusions</div>
            <div class="chip" onclick="useChip(this)">What are the research gaps?</div>
          </div>
        </div>
      </div>
      <div class="input-bar">
        <select class="mode-sel" id="qMode">
          <option>Q&A</option>
          <option>Summarize</option>
          <option>Compare</option>
          <option>Extract Data</option>
        </select>
        <textarea class="q-input" id="qi"
          placeholder="Ask anything about your research papers…"
          rows="1"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendQ()}"
          oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
        <button class="send-btn" id="sBtn" onclick="sendQ()">→</button>
      </div>
    </div>

    <!-- SUMMARY VIEW -->
    <div id="view-summary" class="tool-view">
      <div class="tool-bar">
        <button class="btn-sm" id="sumBtn" onclick="doSummary()">✨ Summarize All Papers</button>
        <span style="color:var(--muted);font-size:11px;">Key findings · Methods · Conclusions for each paper</span>
      </div>
      <div class="tool-body">
        <div class="sum-grid" id="sumGrid">
          <div class="load-card" style="grid-column:1/-1;"><p style="color:var(--muted);font-size:12px;">Add papers then click Summarize All</p></div>
        </div>
      </div>
    </div>

    <!-- COMPARE VIEW -->
    <div id="view-compare" class="tool-view">
      <div class="tool-bar">
        <button class="btn-sm" onclick="doCompare()">⚖️ Compare All Papers</button>
        <span style="color:var(--muted);font-size:11px;">Methods · Findings · Agreements · Gaps</span>
      </div>
      <div class="tool-body" id="cmpArea">
        <div class="empty-state" style="padding:28px;font-size:11px;">Add 2+ papers and click Compare</div>
      </div>
    </div>

    <!-- EXTRACT VIEW -->
    <div id="view-extract" class="tool-view">
      <div class="tool-bar">
        <button class="btn-sm" onclick="doExtract('stats')" style="background:#c84af0;color:#fff">📊 Stats</button>
        <button class="btn-sm" onclick="doExtract('methods')" style="background:#4a7ff0;color:#fff">🔬 Methods</button>
        <button class="btn-sm" onclick="doExtract('conclusions')" style="background:#f0c84a;color:#000">🎯 Conclusions</button>
        <button class="btn-sm" onclick="doExtract('gaps')" style="background:#f04a4a;color:#fff">⚠️ Gaps</button>
      </div>
      <div class="tool-body" id="extArea">
        <div class="empty-state" style="padding:28px;font-size:11px;">Choose what to extract</div>
      </div>
    </div>

  </main>
</div>

<div id="toast" class="toast hidden"></div>

<script>
// ═══════════ STATE ═══════════
const papers = [];
let sessions = [];
let activeSid = null;
let busy = false;

// ═══════════ SESSION ═══════════
function newChat() {
  const sid = 'c' + Date.now();
  sessions.unshift({ id: sid, name: 'New Chat', messages: [], ts: Date.now() });
  activeSid = sid;
  renderSessions();
  renderChat();
  updateStats();
}

function activateSession(sid) {
  activeSid = sid;
  renderSessions();
  renderChat();
  updateStats();
}

function getSession(sid) { return sessions.find(s => s.id === sid) || null; }
function activeSession() { return getSession(activeSid); }

function deleteSession(sid) {
  confirm2('Delete this chat?', 'This cannot be undone.', () => {
    sessions = sessions.filter(s => s.id !== sid);
    if (activeSid === sid) activeSid = sessions[0]?.id || null;
    renderSessions();
    renderChat();
    updateStats();
  });
}

function startRename(sid) {
  const el = document.getElementById('sn_' + sid);
  if (!el) return;
  const cur = el.textContent;
  const inp = document.createElement('input');
  inp.className = 's-rename-input';
  inp.value = cur;
  el.replaceWith(inp);
  inp.focus(); inp.select();
  const commit = () => {
    const s = getSession(sid);
    if (s) s.name = inp.value.trim() || 'Untitled';
    renderSessions(); updateStats();
  };
  inp.addEventListener('blur', commit);
  inp.addEventListener('keydown', e => { if (e.key === 'Enter') inp.blur(); if (e.key === 'Escape') { inp.value = cur; inp.blur(); } });
}

function renderSessions() {
  const el = document.getElementById('sessionList');
  if (!sessions.length) { el.innerHTML = '<div class="no-sessions">No chats yet.<br>Click + to start.</div>'; return; }
  el.innerHTML = sessions.map(s => {
    const act = s.id === activeSid;
    const n = s.messages.length;
    return `
      <div class="session-item ${act ? 'active' : ''}" onclick="activateSession('${s.id}')">
        <span class="s-icon">💬</span>
        <div class="s-info">
          <span class="s-name" id="sn_${s.id}">${esc(s.name)}</span>
          <span class="s-meta">${n} msg${n!==1?'s':''} · ${ago(s.ts)}</span>
        </div>
        <div class="s-actions" onclick="event.stopPropagation()">
          <button class="s-btn" onclick="startRename('${s.id}')" title="Rename">✏️</button>
          <button class="s-btn del" onclick="deleteSession('${s.id}')" title="Delete">🗑</button>
        </div>
      </div>`;
  }).join('');
}

// ═══════════ CHAT RENDER ═══════════
function renderChat() {
  const area = document.getElementById('chatArea');
  const s = activeSession();

  if (!s) {
    area.innerHTML = `<div class="welcome" id="wlc">
      <div class="welcome-glyph">🧬</div>
      <h1>Research Intelligence</h1>
      <p>Click <strong style="color:var(--accent)">+</strong> to start a new chat, then add papers to your library.</p>
    </div>`; return;
  }

  if (!s.messages.length) {
    area.innerHTML = `<div class="welcome" id="wlc">
      <div class="welcome-glyph">🧬</div>
      <h1>${esc(s.name)}</h1>
      <p>Add papers to your library then ask anything about them.</p>
      <div class="chips">
        <div class="chip" onclick="useChip(this)">What are the key findings?</div>
        <div class="chip" onclick="useChip(this)">Compare methodologies</div>
        <div class="chip" onclick="useChip(this)">Extract stats &amp; sample sizes</div>
        <div class="chip" onclick="useChip(this)">Summarize conclusions</div>
        <div class="chip" onclick="useChip(this)">What are the research gaps?</div>
      </div>
    </div>`; return;
  }

  area.innerHTML = '';
  for (const m of s.messages) addMsgDOM(m.role, m.text, m.sources || []);
  area.scrollTop = area.scrollHeight;
}

function addMsgDOM(role, text, srcs) {
  const area = document.getElementById('chatArea');
  const d = document.createElement('div');
  d.className = `message ${role === 'user' ? 'user' : 'ai'}`;
  const body = role === 'ai' ? fmtMd(text) : `<p>${esc(text)}</p>`;
  const srcHtml = srcs.length
    ? `<div class="src-chips">${srcs.map(s=>`<span class="src-chip">📄 ${esc(s)}…</span>`).join('')}</div>` : '';
  d.innerHTML = `
    <div class="av ${role==='user'?'usr':'ai'}">${role==='user'?'👤':'🧬'}</div>
    <div class="bubble">${body}${srcHtml}</div>`;
  area.appendChild(d);
  area.scrollTop = area.scrollHeight;
}

function addTyping() {
  const area = document.getElementById('chatArea');
  const tid = 't' + Date.now();
  area.insertAdjacentHTML('beforeend', `
    <div class="message ai" id="${tid}">
      <div class="av ai">🧬</div>
      <div class="bubble"><div class="typing-ind">
        <div class="t-dot"></div><div class="t-dot"></div><div class="t-dot"></div>
      </div></div>
    </div>`);
  area.scrollTop = area.scrollHeight;
  return tid;
}
function rmTyping(tid) { const e = document.getElementById(tid); if (e) e.remove(); }

// ═══════════ SEND ═══════════
function useChip(el) { document.getElementById('qi').value = el.textContent; sendQ(); }

async function sendQ() {
  const inp = document.getElementById('qi');
  const q = inp.value.trim();
  if (!q || busy) return;

  if (!activeSid) { newChat(); }
  if (!papers.length) { toast('⚠️ Add papers to your library first'); return; }

  const s = activeSession();
  const mode = document.getElementById('qMode').value;
  inp.value = ''; inp.style.height = 'auto';

  const wlc = document.getElementById('wlc');
  if (wlc) wlc.remove();

  s.messages.push({ role: 'user', text: q, sources: [] });
  if (s.messages.length === 1) { s.name = q.slice(0, 36) + (q.length > 36 ? '…' : ''); renderSessions(); updateStats(); }

  addMsgDOM('user', q, []);
  const tid = addTyping();
  busy = true;
  document.getElementById('sBtn').disabled = true;

  const sys = `You are Scholara, expert AI research assistant. ${papers.length} paper(s) in library. Ground all answers in provided content. Cite paper titles. Mode: ${mode}. Use **bold** for emphasis.`;
  const hist = s.messages.slice(-10).map(m => ({ role: m.role === 'user' ? 'user' : 'assistant', content: m.text }));
  hist[hist.length - 1] = { role: 'user', content: `Papers:\n\n${buildCtx()}\n\n---\nQuestion: ${q}` };

  try {
    const ans = await claude(hist, sys);
    rmTyping(tid);
    const srcs = papers.map(p => p.title.slice(0, 26));
    s.messages.push({ role: 'ai', text: ans, sources: srcs });
    addMsgDOM('ai', ans, srcs);
    updateStats(); renderSessions();
  } catch(e) {
    rmTyping(tid);
    const err = `⚠️ ${e.message}`;
    s.messages.push({ role: 'ai', text: err, sources: [] });
    addMsgDOM('ai', err, []);
  }
  busy = false;
  document.getElementById('sBtn').disabled = false;
}

// ═══════════ VIEW SWITCH ═══════════
const VIEWS = ['chat', 'summary', 'compare', 'extract'];
function switchView(v) {
  VIEWS.forEach(n => {
    document.getElementById('tab-' + n).classList.toggle('active', n === v);
    const el = document.getElementById('view-' + n);
    if (n === 'chat') { el.style.display = n === v ? 'flex' : 'none'; }
    else { el.classList.toggle('tv-active', n === v); }
  });
}

// ═══════════ PAPERS ═══════════
document.getElementById('fi').addEventListener('change', async e => { for (const f of e.target.files) await procFile(f); e.target.value = ''; });
const uz = document.getElementById('uz');
uz.addEventListener('dragover', e => { e.preventDefault(); uz.classList.add('drag-over'); });
uz.addEventListener('dragleave', () => uz.classList.remove('drag-over'));
uz.addEventListener('drop', async e => { e.preventDefault(); uz.classList.remove('drag-over'); for (const f of e.dataTransfer.files) await procFile(f); });

async function procFile(f) {
  if (!f.name.match(/\.(pdf|txt)$/i)) { toast('Only PDF & TXT supported'); return; }
  const txt = await new Promise(res => { const r = new FileReader(); r.onload = e => res(e.target.result||''); r.readAsText(f); });
  addPaper({ id: Date.now()+Math.random(), title: f.name.replace(/\.(pdf|txt)$/i,''), content: txt.slice(0,12000), source:'upload', year: new Date().getFullYear() });
  toast(`📄 Added: ${f.name.slice(0,40)}`);
}

async function searchArxiv() {
  const q = document.getElementById('aq').value.trim();
  if (!q) return;
  const btn = document.getElementById('aBtn');
  btn.disabled = true; btn.textContent = '…';
  try {
    const r = await claude([{ role:'user', content:`Research query: "${q}". Return JSON array of 3 realistic paper objects: title, authors, year(2019-2024), abstract(2-3 sentences), arxiv_id(like "2309.12345"), topic. ONLY JSON array.` }],
      'Return ONLY a valid JSON array. No markdown, no extra text.');
    const found = JSON.parse(r.replace(/```json|```/g,'').trim());
    for (const p of found) addPaper({ id:Date.now()+Math.random(), title:p.title, content:`Title: ${p.title}\nAuthors: ${p.authors}\nYear: ${p.year}\n\nAbstract: ${p.abstract}`, source:'arxiv', year:p.year, arxiv_id:p.arxiv_id, topic:p.topic });
    toast(`Found ${found.length} papers on "${q}"`);
  } catch(e) { toast('Search failed. Check API.'); }
  btn.disabled = false; btn.textContent = 'Find';
}

function addPaper(p) { papers.push(p); renderPapers(); document.getElementById('sPapers').textContent = papers.length; }
function rmPaper(id) { const i = papers.findIndex(p=>p.id==id); if(i>-1) papers.splice(i,1); renderPapers(); document.getElementById('sPapers').textContent = papers.length; }
function renderPapers() {
  const el = document.getElementById('paperList'); const b = document.getElementById('pBadge');
  if (!papers.length) { el.innerHTML='<div class="empty-state">No papers yet.</div>'; b.classList.add('hidden'); return; }
  b.textContent=papers.length; b.classList.remove('hidden');
  el.innerHTML=papers.map(p=>`
    <div class="paper-card">
      <button class="pc-remove" onclick="rmPaper(${p.id})">×</button>
      <div class="pc-title">${esc(p.title)}</div>
      <div class="pc-meta">${p.year||''}${p.arxiv_id?' · '+p.arxiv_id:''}</div>
      <span class="pc-tag">${p.source==='arxiv'?'🔎 arXiv':'📄 Upload'}</span>
    </div>`).join('');
}

// ═══════════ TOOLS ═══════════
async function doSummary() {
  if (!papers.length) { toast('No papers'); return; }
  const g = document.getElementById('sumGrid');
  g.innerHTML=`<div class="load-card" style="grid-column:1/-1"><div class="spin"></div><p>Summarizing ${papers.length} paper(s)…</p></div>`;
  document.getElementById('sumBtn').disabled = true;
  const res = [];
  for (const p of papers) {
    try {
      const r = await claude([{role:'user',content:`Summarize: "${p.title}"\n\n${p.content}`}],
        'Return JSON only: {title,key_findings:[3 strings],methods:string,conclusion:string,tags:[3 strings]}');
      res.push({p, d: JSON.parse(r.replace(/```json|```/g,'').trim())});
    } catch { res.push({p, d:null}); }
  }
  g.innerHTML = res.map(({p,d}) => d ? `
    <div class="sum-card">
      <h4>${esc(d.title||p.title)}</h4>
      <p style="color:var(--accent);font-size:10px;font-weight:600;margin-bottom:4px;letter-spacing:1px;">KEY FINDINGS</p>
      <ul style="padding-left:13px;font-size:11px;color:#9ca3af;line-height:1.6">${(d.key_findings||[]).map(f=>`<li>${esc(f)}</li>`).join('')}</ul>
      <p style="margin-top:7px;font-size:11px;color:#9ca3af"><strong style="color:var(--accent2)">Methods:</strong> ${esc(d.methods||'—')}</p>
      <p style="margin-top:4px;font-size:11px;color:#9ca3af"><strong style="color:var(--accent2)">Conclusion:</strong> ${esc(d.conclusion||'—')}</p>
      <div class="tags">${(d.tags||[]).map(t=>`<span class="tag">${esc(t)}</span>`).join('')}</div>
    </div>` : `<div class="sum-card"><h4>${esc(p.title)}</h4><p>Could not summarize.</p></div>`
  ).join('');
  document.getElementById('sumBtn').disabled = false;
}

async function doCompare() {
  if (papers.length < 2) { toast('Need 2+ papers'); return; }
  const a = document.getElementById('cmpArea');
  a.innerHTML=`<div class="load-card"><div class="spin"></div><p>Comparing…</p></div>`;
  const r = await claude([{role:'user',content:`Compare ${papers.length} papers:\n\n${buildCtx()}`}],
    'Compare across: (1) Research Questions (2) Methodologies (3) Key Findings (4) Agreements & Disagreements (5) Gaps. Use **bold headers**, cite paper titles.');
  a.innerHTML=`<div class="message ai"><div class="av ai">🧬</div><div class="bubble" style="max-width:93%">${fmtMd(r)}</div></div>`;
}

async function doExtract(type) {
  if (!papers.length) { toast('No papers'); return; }
  const a = document.getElementById('extArea');
  a.innerHTML=`<div class="load-card"><div class="spin"></div><p>Extracting…</p></div>`;
  const pm = {
    stats:'Extract ALL numerical data: statistics, sample sizes, percentages, p-values, effect sizes, confidence intervals. Organize by paper.',
    methods:'Extract research methodology: study design, data collection, analysis methods, tools.',
    conclusions:'Extract main conclusions, implications, recommendations.',
    gaps:'Identify research gaps, limitations, future work.'
  };
  const r = await claude([{role:'user',content:`${pm[type]}\n\nPapers:\n${buildCtx()}`}],
    'Be precise and organized. Use **bold** for paper names.');
  a.innerHTML=`<div class="message ai"><div class="av ai">🧬</div><div class="bubble" style="max-width:93%">${fmtMd(r)}</div></div>`;
}

// ═══════════ API ═══════════
async function claude(messages, system='You are a helpful AI.') {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({ model:'claude-sonnet-4-20250514', max_tokens:1000, system, messages })
  });
  if (!res.ok) { const e=await res.json().catch(()=>({})); throw new Error(e.error?.message||`HTTP ${res.status}`); }
  const d = await res.json();
  return d.content.map(b=>b.text||'').join('');
}

// ═══════════ UTILS ═══════════
function buildCtx() { return papers.map((p,i)=>`[Paper ${i+1}] "${p.title}" (${p.year||'n/d'})\n${p.content.slice(0,3000)}`).join('\n\n---\n\n'); }
function updateStats() {
  const s = activeSession();
  document.getElementById('sChatName').textContent = s ? (s.name.slice(0,20)+(s.name.length>20?'…':'')) : '—';
  document.getElementById('sMsgs').textContent = s ? s.messages.length : 0;
}
function fmtMd(t) {
  return t
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/^#{1,3} (.+)/gm,'<h3>$1</h3>')
    .replace(/^[-*] (.+)/gm,'<li>$1</li>')
    .replace(/(<li>[\s\S]*?<\/li>)/g,m=>'<ul>'+m+'</ul>')
    .replace(/\n\n/g,'</p><p>')
    .replace(/^(?!<[hul])(.+)$/gm,'<p>$1</p>')
    .replace(/<p><\/p>/g,'');
}
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function ago(ts) {
  const d=Date.now()-ts;
  if(d<60000) return 'just now';
  if(d<3600000) return Math.floor(d/60000)+'m ago';
  if(d<86400000) return Math.floor(d/3600000)+'h ago';
  return Math.floor(d/86400000)+'d ago';
}
let toastT;
function toast(msg) { const t=document.getElementById('toast'); t.textContent=msg; t.classList.remove('hidden'); clearTimeout(toastT); toastT=setTimeout(()=>t.classList.add('hidden'),3000); }
function confirm2(title, msg, cb) {
  const o=document.createElement('div'); o.className='confirm-overlay';
  o.innerHTML=`<div class="confirm-box"><h3>${esc(title)}</h3><p>${esc(msg)}</p><div class="confirm-btns"><button class="btn-no">Cancel</button><button class="btn-ok">Delete</button></div></div>`;
  document.body.appendChild(o);
  o.querySelector('.btn-no').onclick=()=>o.remove();
  o.querySelector('.btn-ok').onclick=()=>{o.remove();cb();};
}

document.getElementById('aq').addEventListener('keydown', e => { if(e.key==='Enter') searchArxiv(); });

// Auto-create first chat on load
newChat();
</script>
